# MiniAdsWall Agent 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_NAME=MiniAdsWall Agent
APP_ENV=production
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：覆盖为兼容 Anthropic 协议的第三方 API（如 DeepSeek）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 可选：覆盖模型名称（默认 claude-3-5-sonnet-20241022）
# 使用 DeepSeek 时设为 deepseek-chat
# ANTHROPIC_MODEL=deepseek-chat

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=miniadswall123

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
ANOMALY_DETECTION_THRESHOLD=2.0

# ── 评测 ──────────────────────────────────────────────────────────────────────
EVAL_BASELINE_PATH=./data/eval/baseline.json

# ── Skills ───────────────────────────────────────────────────────────────────
# 默认读取项目内 ./skills，支持运行时通过 POST /skills/reload 热加载
ECHOMIND_SKILLS_DIR=./skills
ECHOMIND_SKILLS_MAX_PROMPT_CHARS=5000

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── 功能开关 ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true
